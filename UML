@startuml
' Llama Board Game UML (Java)

package "Model" {
  class Game {
    - players: List<Player>
    - drawPile: Deck
    - discardPile: Deck
    - tokens: Tokens
    - currentPlayerIndex: int
    + start(): void
    + nextTurn(): void
    + applyMove(move: Move): void
    + isOver(): boolean
    + getWinner(): Player
  }
class Bot {

    difficulty: Difficulty

    decideMove(game: Game): Move
    setDifficulty(d: Difficulty): void 
} 
class Player {
- name: String
- hand: List
- tokenType: TokenType
- score: int
+ addCard(card: CardType): void
+ removeCard(card: CardType): void
+ changeState(state: State): void
+ addToken(token: TokenType): void
}

class Tokens {
- tokens: Map<TokenType, Integer>
+ createFull(): Tokens
+ isEmpty(type: TokenType): boolean
+ takeToken(type: TokenType): boolean
}

class Deck {
- cards: Queue
+ shuffle(): void
+ draw(): CardType
+ peek(): CardType
+ isEmpty(): boolean
+ add(card: CardType): void
+ createFull(): Deck
}


  class Move {
    - player: Player
    - type: MoveType
    - card: CardType
    - token: TokenType
    + execute(game: Game): void
  }

  class RuleEngine {
    - rules: List<Rule>
    + validateMove(move: Move, game: Game): boolean
    + applyRules(move: Move, game: Game): void
  }

  interface Rule {
    + isApplicable(move: Move, game: Game): boolean
    + apply(move: Move, game: Game): void
  }

enum Difficulty { 
    EASY 
    MEDIUM 
    HARD 
}
enum MoveType {
    TAKETOKEN
    GIVETOKEN
    TAKECARD
    GIVECARD
}

enum State {
    QUITTING
    PLAYING
}

enum TokenType {
    BLACK
    WHITE
}

enum CardType {
    ONE
    TWO
    THREE
    FOUR
    FIVE
    SIX
    LLAMA
}
}

' Relationships
Game "1" *-- "*" Player : players
Game "1" *-- "1" Deck : drawPile
Game "1" *-- "1" Deck : discardPile
Game "1" *-- "1" Tokens : tokens

Player "1" --> "0..1" Game : currentGame
Move "1" --> "1" Player
Move "1" --> "0..1" Game
Move "1" --> "0..1" TokenType
Move "1" --> "0..1" CardType

Deck "1" *-- "*" CardType : cards

RuleEngine "1" o-- "*" Rule : rules
Bot -|> "extends" Player
Game "1" *-- "*" Bot : players
Rule <|.. RuleEngine

package "view"{
class MainFrame {
        - currentScreen: JPanel
        + showMenu(): void
        + showSettings(): void
        + showGame(): void
    }

    class MenuView {
        - btnStart: Button
        - btnSettings: Button
        - btnQuit: Button
        + onStartClicked(): void
    }

    class SettingsView {
        - comboNbPlayers: ComboBox
        - comboDifficulty: ComboBox
        + saveSettings(): void
    }

    class BoardView {
        - drawPile: DrawPileView
        - discardPile: DiscardPileView
        - players: List<PlayerView>
        - currentPlayerPanel: PlayerView
        + updateBoard(gameModel: Game): void
    }

    class PlayerView {
        - playerName: String
        - handView: HandView
        - scoreLabel: Label
        - isBot: boolean
        + displayPlayerInfo(): void
    }

    class CardView {
        - image: Image
        - type: CardType
        + render(): void
    }

    class HandView {
        - cards: List<CardView>
        + layoutCards(): void
    }
}

' Relationships
MainFrame "1" *-- "1" MenuView
MainFrame "1" *-- "1" SettingsView
MainFrame "1" *-- "1" BoardView

BoardView "1" *-- "1..*" PlayerView : contains
BoardView "1" *-- "1" CardView : shows_piles

PlayerView "1" *-- "1" HandView
HandView "1" *-- "*" CardView

package "Controller" {

    class GameController {
        - gameModel: Game
        - mainFrame: MainFrame
        + GameController(model: Game, view: MainFrame)
        + initController(): void
        + startGame(): void
        + showSettings(): void
    }

    class BoardController {
        - gameModel: Game
        - boardView: BoardView
        + handleDrawCard(): void
        + handlePlayCard(card: CardType): void
        + handleQuitRound(): void
        - updateView(): void
        - checkBotTurn(): void
    }

    class MenuController {
        - mainFrame: MainFrame
        + handleStartGame(): void
        + handleOpenSettings(): void
        + handleExit(): void
    }

    class SettingsController {
        - gameModel: Game
        - settingsView: SettingsView
        + handleSaveSettings(nbPlayers: int, diff: Difficulty): void
    }
}

' Relations avec les autres couches (simplifiées)
GameController "1" --> "1" MenuController
GameController "1" --> "1" BoardController
GameController "1" --> "1" SettingsController

BoardController ..> "Model" Game : modifies
BoardController ..> "View" BoardView : updates
@enduml
